{
  "name": "netpaste",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Clean messy network CLI output locally before sharing it.",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "build:extension": "node scripts/generate-extension-icons.mjs && tsc --noEmit && vite build --config vite.extension.config.ts",
    "package:extension": "npm run build:extension && node scripts/package-extension.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
